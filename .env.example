# Dark Phoenix — example environment file
#
# Copy this file to `.env` (in this same project root) and fill in real values.
# The `.env` file is gitignored — never commit it.
#
# This is the single source of environment variables for the whole project:
#   • The Next.js frontend loads it via `@next/env` from
#     ai-podcast-clipper-frontend/next.config.js (loadEnvConfig('..'))
#   • The Modal Python backend loads it via python-dotenv from
#     ai-podcast-clipper-backend/setup_modal_secret.py (load_dotenv("../.env"))
#
# When you add a new variable here, also update
# ai-podcast-clipper-frontend/src/env.js so the runtime validation knows about it.

# --- NextAuth ---------------------------------------------------------------
# Generate with: npx auth secret
AUTH_SECRET=""

# --- Database (Supabase Postgres) -------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=""

# --- AWS S3 (video storage) -------------------------------------------------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
S3_BUCKET_NAME=""

# --- Modal backend (video processing endpoint) ------------------------------
# Public URL printed by `modal deploy main.py`
PROCESS_VIDEO_ENDPOINT=""
# Shared bearer token — same value must be AUTH_TOKEN in the Modal secret
PROCESS_VIDEO_ENDPOINT_AUTH=""

# --- Stripe (OPTIONAL for review path — credits are pre-seeded in DB) ------
# Leave blank to disable billing; the app will start but the billing page
# won't work.  Set to test-mode keys if you want billing to function.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_SMALL_CREDIT_PACK=""
STRIPE_MEDIUM_CREDIT_PACK=""
STRIPE_LARGE_CREDIT_PACK=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Gemini AI (used by the Modal backend via Modal Secret) ----------------
GEMINI_API_KEY=""

# --- App URL ----------------------------------------------------------------
BASE_URL="http://localhost:3000"
